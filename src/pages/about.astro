					</li>
					<li>
						<a href="https://x.com/solanky" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" title="X (Twitter)">
							<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.2 2.3h3.3l-7.2 8.3 8.5 11.2h-6.7l-5.2-6.8-6 6.8H1.6l7.7-8.8L1.2 2.3H8l4.7 6.2 5.5-6.2Zm-1.2 17.5h1.8L7 4.1H5L17 19.8Z" /></svg>
						</a>
					</li>
					<li>
						<a href="https://www.linkedin.com/in/solanky/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" title="LinkedIn">
							<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.5 3H3.5A1.5 1.5 0 0 0 2 4.5v15A1.5 1.5 0 0 0 3.5 21h17a1.5 1.5 0 0 0 1.5-1.5v-15A1.5 1.5 0 0 0 20.5 3ZM8 18H5V9h3v9ZM6.5 7.8A1.8 1.8 0 1 1 6.5 4a1.8 1.8 0 0 1 0 3.8ZM19 18h-3v-4.4c0-1.1 0-2.4-1.5-2.4S12.8 12.3 12.8 13.5V18h-3V9h2.9v1.2c.4-.8 1.4-1.5 2.7-1.5 3 0 3.6 2 3.6 4.5V18Z" /></svg>
