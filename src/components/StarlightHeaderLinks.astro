---
const product = Astro.url.pathname.match(/^\/openza\/(tasks|reader|flow)(?:\/|$)/)?.[1];
const repositories = {
	tasks: { name: 'Openza Tasks', url: 'https://github.com/openza/tasks' },
	reader: { name: 'Openza Reader', url: 'https://github.com/openza/reader' },
	flow: { name: 'Openza Flow', url: 'https://github.com/openza/flow' },
} as const;
const repository = product ? repositories[product as keyof typeof repositories] : undefined;
---

<a class="site-home" href="/">solanky.dev</a>
{
	repository && (
		<a class="github-link" href={repository.url} aria-label={repository.name + ' source on GitHub'} title="GitHub">
			<svg viewBox="0 0 24 24" aria-hidden="true">
				<path d="M12 .7a11.3 11.3 0 0 0-3.6 22c.6.1.8-.2.8-.5v-2.2c-3.3.7-4-1.4-4-1.4-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.6.1-3.2 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C16.8 5 18 5.5 18 5.5c.6 1.6.2 2.9.1 3.2.8.9 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.2c0 .3.2.6.8.5A11.3 11.3 0 0 0 12 .7Z" />
			</svg>
		</a>
	)
}

<style>
	@layer starlight.core {
		a {
			color: var(--sl-color-text-accent);
		}

		a:hover {
			color: var(--sl-color-white);
		}

		.site-home {
			font-size: var(--sl-text-sm);
			font-weight: 650;
			text-decoration: none;
			white-space: nowrap;
		}

		.github-link {
			display: flex;
			padding: 0.5em;
			margin: -0.5em;
		}

		svg {
			width: 1.25rem;
			height: 1.25rem;
			fill: currentColor;
		}
	}
</style>